# jero 환경변수 예시 — 실제 값은 .env.local 에 넣고 절대 커밋하지 않는다.
# NEXT_PUBLIC_ 접두는 "클라이언트에 노출돼도 되는 값"에만 사용한다(서버 시크릿에 붙이지 말 것).

# Google Maps (클라이언트 노출 전제 — 콘솔에서 HTTP referrer + API 범위 제한을 건다)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID (선택) — AdvancedMarkerElement 사용 시 필요. 없으면 OverlayView 폴백으로 동작.
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Supabase (백엔드 확정 시 사용)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # 서버 전용 — 절대 NEXT_PUBLIC_ 금지
